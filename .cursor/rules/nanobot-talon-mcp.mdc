## Tool Definition Template (TypeScript)

```typescript
import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { z } from "zod";

export function registerSearxngTools(server: McpServer, searxngUrl: string) {
  server.tool(
    "searxng_search",
    "Search the web via local SearXNG instance",
    {
      query: z.string().min(1).describe("Search query"),
      categories: z.enum(["general", "news", "images", "science"]).optional().default("general"),
      num_results: z.number().int().min(1).max(20).optional().default(5),
    },
    async ({ query, categories, num_results }) => {
      const url = new URL(`${searxngUrl}/search`);
      url.searchParams.set("q", query);
      url.searchParams.set("categories", categories ?? "general");
      url.searchParams.set("format", "json");
      url.searchParams.set("pageno", "1");

      const res = await fetch(url.toString());
      if (!res.ok) throw new Error(`SearXNG error: ${res.status}`);
      const data = await res.json() as { results: Array<{ title: string; url: string; content: string }> };

      const results = data.results.slice(0, num_results).map(r => ({
        title: r.title,
        url: r.url,
        snippet: r.content.replace(/<[^>]+>/g, "").trim(),
      }));

      return {
        content: [{ type: "text", text: JSON.stringify(results, null, 2) }],
      };
    }
  );
}
```

