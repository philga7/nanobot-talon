# tests/test_memory_pipeline.py
async def test_propose_creates_pending_entry(client, db_session):
    resp = await client.post("/memories/propose", json={
        "tier": "core",
        "category": "behavior",
        "key": "test_key",
        "value": "test value",
        "context": "test context",
        "source": "agent",
    })
    assert resp.status_code == 201
    pending = await db_session.get(PendingMemory, resp.json()["id"])
    assert pending.status == "pending"

async def test_approve_writes_memory_md(client, tmp_workspace, db_session):
    # Create pending entry, approve it, verify MEMORY.md updated
    candidate = PendingMemory(tier="core", category="behavior", key="k", value="v", source="test")
    db_session.add(candidate)
    await db_session.commit()

    resp = await client.post(f"/pending/{candidate.id}/approve")
    assert resp.status_code == 200

    memory_md = (tmp_workspace / "MEMORY.md").read_text()
    assert "v" in memory_md  # value appears in rendered MEMORY.md

