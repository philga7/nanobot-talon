{
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot-wren-air/workspace",
      "model": "gemini-3-flash-preview:cloud",
      "provider": "custom",
      "memoryWindow": 100
    }
  },
  "providers": {
    "custom": {
      "apiKey": "REPLACE_ME_API_KEY",
      "apiBase": "https://ollama.com/v1"
    }
  },
  "gateway": {
    "port": 18791
  },
  "tools": {
    "web": {
      "search": {
        "searxngBaseUrl": "http://host.docker.internal:8080"
      }
    },
    "restrictToWorkspace": false,
    "mcpServers": {
      "ntfy": {
        "command": "npx",
        "args": [
          "-y",
          "ntfy-me-mcp"
        ],
        "env": {
          "NTFY_TOPIC": "wrenair-notifications",
          "NTFY_URL": "https://ntfy.informedcrew.com",
          "NTFY_TOKEN": "REPLACE_ME_NTFY_TOKEN"
        }
      },
      "nanobot-file-store": {
        "command": "node",
        "args": [
          "/app/services/nanobot-file-store-mcp/dist/index.js"
        ],
        "env": {
          "OPENCLAW_DATA_ROOT": "/path/to/your/Obsidian/Vault"
        },
        "toolTimeout": 30
      }
    }
  },
  "mem0": {
    "enabled": true,
    "apiUrl": "http://host.docker.internal:3002",
    "userId": "wren-air",
    "autoRecall": true,
    "autoCapture": true,
    "topK": 5
  }
}
